apiVersion: v1
kind: Secret
metadata:
  name: ipnfyi-secret
  namespace: ipnfyi
type: Opaque
stringData:
  DATABASE_URL: "postgresql://user:password@host.neon.tech/dbname?sslmode=require"
---
# To create the secret from command line instead:
# kubectl create secret generic ipnfyi-secret \
#   --from-literal=DATABASE_URL='postgresql://user:password@host.neon.tech/dbname?sslmode=require' \
#   -n ipnfyi
